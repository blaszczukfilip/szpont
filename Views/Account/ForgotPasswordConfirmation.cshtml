@{
    ViewData["Title"] = "Wysłano link resetujący";
}

<style>
    body {
        background-color: #121212;
        color: #f1f1f1;
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .register-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .card {
        width: 400px;
        border: 2px solid #333;
        border-radius: 8px;
        background-color: #1f1f1f;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
        text-align: center;
    }

    .card-header {
        background-color: #2a2a2a;
        border-bottom: 1px solid #333;
        font-size: 1.5rem;
        font-weight: 600;
        color: #f1f1f1;
        padding: 1rem;
    }

    .card-body {
        padding: 1rem;
    }

    .btn-primary {
        width: 100%;
        background-color: #007bff;
        border: none;
        font-weight: 500;
        padding: 10px;
        border-radius: 4px;
        color: white;
        text-decoration: none;
        display: inline-block;
        margin-top: 10px;
        transition: 0.2s;
    }

        .btn-primary:hover {
            background-color: #0056b3;
        }

    a {
        color: #76b7ff;
        text-decoration: none;
    }

        a:hover {
            color: #a9d3ff;
            text-decoration: underline;
        }
</style>

<div class="register-container">
    <div class="card">
        <div class="card-header">Reset hasła</div>
        <div class="card-body">
            <p>
                Jeśli istnieje konto z podanym adresem e-mail, wysłano link do resetowania hasła.
            </p>
            <a class="btn-primary" asp-controller="Account" asp-action="Login">Powrót do logowania</a>
        </div>
    </div>
</div>
