@model szpont.Models.RegisterViewModel
@{
    ViewData["Title"] = "Rejestracja";
}

<style>
    body {
        background-color: #121212;
        color: #f1f1f1;
        margin: 0;
        padding: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .register-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .card {
        width: 400px;
        border: 2px solid #333;
        border-radius: 8px;
        background-color: #1f1f1f;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
    }

    .card-header {
        background-color: #2a2a2a;
        border-bottom: 1px solid #333;
        font-size: 1.8rem;
        font-weight: 600;
        color: #f1f1f1;
        text-align: left;
        padding: 0.75rem 1rem;
    }

    .form-control {
        border: 1px solid #555;
        border-radius: 4px;
        background-color: #121212;
        color: #f1f1f1;
    }

        .form-control:focus {
            border-color: #007bff;
            box-shadow: none;
            background-color: #1a1a1a;
            color: #fff;
        }

    .form-check-label {
        color: #f1f1f1;
    }

    .btn-primary {
        width: 100%;
        background-color: #007bff;
        border: none;
        font-weight: 500;
        padding: 10px;
        border-radius: 4px;
        color: white;
        transition: 0.2s;
    }

        .btn-primary:hover {
            background-color: #0056b3;
        }

    a {
        color: #76b7ff;
        text-decoration: none;
    }

        a:hover {
            color: #a9d3ff;
            text-decoration: underline;
        }

    .text-danger {
        color: #ff6b6b !important;
    }
</style>

<div class="register-container">
    <div class="card p-4">
        <div class="card-header">Rejestracja</div>
        <div class="card-body">
            <form asp-controller="Account" asp-action="Register" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="StudentIndex" class="form-label"></label>
                    <input asp-for="StudentIndex" class="form-control" />
                    <span asp-validation-for="StudentIndex" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" type="password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Zarejestruj się</button>
            </form>

            <div class="text-center mt-3">
                <small>
                    Masz już konto?
                    <a asp-controller="Account" asp-action="Login">Zaloguj się</a>
                </small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
