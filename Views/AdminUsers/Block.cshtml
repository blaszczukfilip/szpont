@model ApplicationUser

@{
    ViewData["Title"] = "Potwierdzenie blokady";
}

<h2>Potwierdzenie blokady</h2>

<div class="form-box">
    <div class="alert alert-danger">
        <p>
            Czy na pewno chcesz <strong>zablokować</strong> użytkownika:
        </p>
        <ul>
            <li><strong>@Model.FirstName @Model.LastName</strong></li>
            <li>Email: @Model.Email</li>
        </ul>
    </div>

    <form asp-action="BlockConfirmed" method="post">
        <input type="hidden" name="id" value="@Model.Id" />

        <div class="mb-3">
            <label for="lockoutDuration">Czas blokady (w godzinach):</label>
            <input type="number" class="form-control" name="lockoutHours" id="lockoutDuration" value="1" min="1" max="8760" />
            <small class="form-text text-muted">Podaj liczbę godzin, przez które użytkownik ma być zablokowany.</small>
        </div>

        <button type="submit" class="btn btn-danger">
            Zablokuj
        </button>

        <a asp-action="Details"
        asp-route-id="@Model.Id"
        class="btn btn-secondary">
            Anuluj
        </a>
    </form>
</div>

<style>
.form-box {
    padding: 25px;
    margin-bottom: 35px;
    background: rgba(50, 50, 50, 0.9);
    border: 1px solid #777;
    border-radius: 10px;
    color: #fff;
}

.form-field {
    margin-bottom: 20px;
}

.form-box label {
    display: block;
    font-weight: 600;
    margin-bottom: 5px;
    color: #ddd;
}

.form-box input,
.form-box textarea,
.form-box select {
    width: 100%;
    padding: 12px 15px;
    border-radius: 8px;
    border: 1px solid #555;
    background-color: #222;
    color: #fff;
    box-sizing: border-box;
    font-size: 14px;
}

.form-box textarea {
    resize: vertical;
}

.form-box input::placeholder {
    color: #aaa;
}

.form-text {
    color: #ccc;
    font-size: 12px;
}
</style>