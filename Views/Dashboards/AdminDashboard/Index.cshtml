@model szpont.Models.AdminDashboardViewModel
@using System.Linq
@{
    ViewData["Title"] = "Panel administratora";
}

<h1>Panel administratora</h1>

<!-- Karty ze statystykami -->
<div class="stats-cards-container">
    @foreach (var stat in Model.MainStats)
    {
        <div class="stat-card @stat.Value.CssClass">
            <div class="stat-card-body">
                <h5 class="stat-card-title">@stat.Key</h5>
                <h4 class="stat-card-value">@stat.Value.Value</h4>
            </div>
        </div>
    }
</div>

<div class="accordion-container">
    <div class="accordion" id="statsAccordion"> 
        <!-- Tematy wedlug typu -->
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTopics">
                    <strong>Tematy według typu</strong>
                </button>
            </h2>
            <div id="collapseTopics" class="accordion-collapse collapse" data-bs-parent="#statsAccordion">
                <div class="accordion-body">
                    <div class="topics-stats-grid">
                        @foreach (var topicType in Model.TopicsByType)
                        {
                            <div class="topic-stat-card">
                                <h6 class="topic-stat-label">@topicType.Key</h6>
                                <h4 class="topic-stat-value">@topicType.Value</h4>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- szczegolowe statystyki uzytkownikow -->
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseUsers">
                    <strong>Szczegółowe statystyki użytkowników</strong>
                </button>
            </h2>
            <div id="collapseUsers" class="accordion-collapse collapse" data-bs-parent="#statsAccordion">
                <div class="accordion-body">
                    <div class="user-stats-grid">
                        @foreach (var userStat in Model.UserRoleStats)
                        {
                            <div class="user-stat-card">
                                <h6 class="user-stat-label">@userStat.Key</h6>
                                <h4 class="user-stat-value">@userStat.Value</h4>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Wykresy statystyk -->
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCharts">
                    <strong>Wykresy statystyk</strong>
                </button>
            </h2>
            <div id="collapseCharts" class="accordion-collapse collapse" data-bs-parent="#statsAccordion">
                <div class="accordion-body">
                    <div class="charts-container">
                        <div class="chart-card">
                            <div class="chart-card-body">
                                <h5 class="chart-card-title">Rozkład tematów według typu</h5>
                                <canvas id="topicsChart"></canvas>
                            </div>
                        </div>
                        <div class="chart-card">
                            <div class="chart-card-body">
                                <h5 class="chart-card-title">Rozkład użytkowników według roli</h5>
                                <canvas id="usersChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        let topicsChart = null;
        let usersChart = null;

        function initCharts() {
            if (topicsChart || usersChart) return;

            const topicsCtx = document.getElementById('topicsChart'); // wykres tematow
            if (topicsCtx) {
                topicsChart = new Chart(topicsCtx.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: [@Html.Raw(Model.TopicsByType.Any() ? string.Join(", ", Model.TopicsByType.Keys.Select(k => $"'{k.Replace("'", "\\'")}'")) : "''")],
                        datasets: [{
                            label: 'Liczba tematów',
                            data: [@(Model.TopicsByType.Any() ? string.Join(", ", Model.TopicsByType.Values) : "0")],
                            backgroundColor: [
                                'rgba(118, 186, 255, 0.6)',
                                'rgba(118, 250, 255, 0.6)',
                                'rgba(255, 186, 118, 0.6)',
                                'rgba(255, 118, 186, 0.6)',
                                'rgba(186, 118, 255, 0.6)'
                            ],
                            borderColor: [
                                'rgba(118, 186, 255, 1)',
                                'rgba(118, 250, 255, 1)',
                                'rgba(255, 186, 118, 1)',
                                'rgba(255, 118, 186, 1)',
                                'rgba(186, 118, 255, 1)'
                            ],
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: {
                                labels: { color: '#f1f1f1' },
                                position: 'bottom'
                            }
                        }
                    }
                });
            }

            const usersCtx = document.getElementById('usersChart'); // wykres uzytkownikow
            if (usersCtx) {
                usersChart = new Chart(usersCtx.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: [@Html.Raw(Model.UserRoleStats.Any() ? string.Join(", ", Model.UserRoleStats.Select(k => $"'{k.Key.Replace("'", "\\'")}'")) : "''")],
                        datasets: [{
                            label: 'Liczba użytkowników',
                            data: [@(Model.UserRoleStats.Any() ? string.Join(", ", Model.UserRoleStats.Select(k => k.Value)) : "0")],
                            backgroundColor: [
                                'rgba(118, 186, 255, 0.6)',
                                'rgba(118, 250, 255, 0.6)',
                                'rgba(255, 186, 118, 0.6)',
                                'rgba(255, 118, 186, 0.6)',
                                'rgba(186, 118, 255, 0.6)'
                            ],
                            borderColor: [
                                'rgba(118, 186, 255, 1)',
                                'rgba(118, 250, 255, 1)',
                                'rgba(255, 186, 118, 1)',
                                'rgba(255, 118, 186, 1)',
                                'rgba(186, 118, 255, 1)'
                            ],
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { beginAtZero: true, ticks: { color: '#f1f1f1', stepSize: 1 }, grid: { color: 'rgba(255, 255, 255, 0.1)' } },
                            x: { ticks: { color: '#f1f1f1' }, grid: { color: 'rgba(255, 255, 255, 0.1)' } }
                        }
                    }
                });
            }
        }

        const collapseCharts = document.getElementById('collapseCharts');
        if (collapseCharts) {
            collapseCharts.addEventListener('shown.bs.collapse', function () {
                setTimeout(initCharts, 100);
            });
        }
    </script>
}

<style>
h1 {
    margin-bottom: 30px;
    color: #fff;
    font-size: 2rem;
}

.stats-cards-container {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    margin-bottom: 35px;
}

.stat-card {
    padding: 25px;
    border-radius: 10px;
    border: 1px solid #555;
    background-color: rgba(40, 40, 40, 0.95);
    color: #fff;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.stat-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
}

.stat-card-users {
    background-color: rgba(50, 50, 50, 0.9);
    border-color: rgba(186, 118, 255, 0.5);
}

.stat-card-topics {
    background-color: rgba(50, 50, 50, 0.9);
    border-color: rgba(118, 255, 186, 0.5);
}

.stat-card-body {
    text-align: center;
}

.stat-card-title {
    margin-bottom: 15px;
    font-size: 1.1rem;
    font-weight: 600;
    color: #ddd;
    text-transform: uppercase;
}

.stat-card-value {
    margin: 0;
    font-size: 2.5rem;
    font-weight: bold;
    color: #fff;
}

.accordion-container {
    margin-bottom: 35px;
}

.accordion-item {
    background-color: rgba(50, 50, 50, 0.9);
    border: 1px solid #777;
    border-radius: 10px;
    margin-bottom: 15px;
    overflow: hidden;
}

.accordion-button {
    background-color: rgba(50, 50, 50, 0.9);
    color: #fff;
    border: none;
    padding: 18px 25px;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background-color 0.3s ease;
}

.accordion-button:not(.collapsed) {
    background-color: rgba(60, 60, 60, 0.95);
    color: #fff;
    box-shadow: none;
}

.accordion-button:focus {
    box-shadow: 0 0 0 0.25rem rgba(52, 152, 219, 0.25);
    border-color: rgba(52, 152, 219, 0.3);
}

.accordion-button::after {
    filter: brightness(0) invert(1);
}

.accordion-body {
    background-color: rgba(40, 40, 40, 0.95);
    padding: 25px;
    color: #fff;
}

.charts-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 20px;
}

.chart-card {
    background-color: rgba(40, 40, 40, 0.95);
    border: 1px solid #555;
    border-radius: 10px;
    padding: 20px;
}

.chart-card-body {
    text-align: center;
}

.chart-card-title {
    margin-bottom: 20px;
    font-size: 1.1rem;
    font-weight: 600;
    color: #fff;
}

.chart-card canvas {
    max-height: 300px;
}

.user-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 15px;
}

.user-stat-card {
    background-color: rgba(60, 60, 60, 0.95);
    border: 1px solid #555;
    border-radius: 8px;
    padding: 20px;
    text-align: center;
    min-height: 120px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    transition: background-color 0.2s ease;
}

.user-stat-card:hover {
    background-color: rgba(70, 70, 70, 0.95);
}

.user-stat-label {
    margin-bottom: 10px;
    font-size: 0.9rem;
    font-weight: 600;
    color: #ddd;
    text-transform: uppercase;
}

.user-stat-value {
    margin: 0;
    font-size: 2rem;
    font-weight: bold;
    color: #fff;
}

.topics-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 15px;
}

.topic-stat-card {
    background-color: rgba(60, 60, 60, 0.95);
    border: 1px solid #555;
    border-radius: 8px;
    padding: 20px;
    text-align: center;
    min-height: 120px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    transition: background-color 0.2s ease;
}

.topic-stat-card:hover {
    background-color: rgba(70, 70, 70, 0.95);
}

.topic-stat-label {
    margin-bottom: 10px;
    font-size: 0.9rem;
    font-weight: 600;
    color: #ddd;
    text-transform: uppercase;
}

.topic-stat-value {
    margin: 0;
    font-size: 2rem;
    font-weight: bold;
    color: #fff;
}

@@media (max-width: 600px) {
    .stats-cards-container {
        grid-template-columns: 1fr;
    }
    
    .topics-stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .charts-container {
        grid-template-columns: 1fr;
    }
    
    .user-stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}
</style>


