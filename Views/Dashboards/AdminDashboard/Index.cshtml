@model szpont.Models.AdminDashboardViewModel
@using System.Linq
@{
    ViewData["Title"] = "Panel administratora";
}

<div class="dashboard-page">
    <header class="dashboard-header">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
                <h1 class="dashboard-title">Panel administratora</h1>
                <p class="dashboard-subtitle">Zbiorczy podgląd użytkowników, tematów oraz statystyk systemowych.</p>
            </div>
            <div class="export-buttons">
                <div class="dropdown">
                    <button class="btn btn-primary dropdown-toggle" type="button" id="exportDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                        Eksportuj raport
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="exportDropdown">
                        <li><a class="dropdown-item" asp-action="ExportSystemReportTxt">Pobierz jako TXT</a></li>
                        <li><a class="dropdown-item" asp-action="ExportSystemReportCsv">Pobierz jako CSV</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </header>

    <div class="dashboard-stats-grid">
        @foreach (var stat in Model.MainStats)
        {
            <div class="dashboard-stat-card @stat.Value.CssClass">
                <h5 class="dashboard-stat-label">@stat.Key</h5>
                <h4 class="dashboard-stat-value">@stat.Value.Value</h4>
            </div>
        }
    </div>

    <div class="dashboard-accordion-wrapper">
        <div class="accordion dashboard-accordion" id="statsAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTopics">
                        <strong>Tematy według typu</strong>
                    </button>
                </h2>
                <div id="collapseTopics" class="accordion-collapse collapse" data-bs-parent="#statsAccordion">
                    <div class="accordion-body">
                        <div class="dashboard-mini-stats-grid">
                            @foreach (var topicType in Model.TopicsByType)
                            {
                                <div class="dashboard-mini-stat-card">
                                    <h6 class="dashboard-mini-stat-label">@topicType.Key</h6>
                                    <h4 class="dashboard-mini-stat-value">@topicType.Value</h4>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseUsers">
                        <strong>Szczegółowe statystyki użytkowników</strong>
                    </button>
                </h2>
                <div id="collapseUsers" class="accordion-collapse collapse" data-bs-parent="#statsAccordion">
                    <div class="accordion-body">
                        <div class="dashboard-mini-stats-grid">
                            @foreach (var userStat in Model.UserRoleStats)
                            {
                                <div class="dashboard-mini-stat-card">
                                    <h6 class="dashboard-mini-stat-label">@userStat.Key</h6>
                                    <h4 class="dashboard-mini-stat-value">@userStat.Value</h4>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCharts">
                        <strong>Wykresy statystyk</strong>
                    </button>
                </h2>
                <div id="collapseCharts" class="accordion-collapse collapse" data-bs-parent="#statsAccordion">
                    <div class="accordion-body">
                        <div class="dashboard-charts-grid">
                            <div class="dashboard-panel mb-0">
                                <h5 class="dashboard-panel-title">Rozkład tematów według typu</h5>
                                <canvas id="topicsChart"></canvas>
                            </div>
                            <div class="dashboard-panel mb-0">
                                <h5 class="dashboard-panel-title">Rozkład użytkowników według roli</h5>
                                <canvas id="usersChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        let topicsChart = null;
        let usersChart = null;

        function initCharts() {
            if (topicsChart || usersChart) return;

            const topicsCtx = document.getElementById('topicsChart');
            if (topicsCtx) {
                topicsChart = new Chart(topicsCtx.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: [@Html.Raw(Model.TopicsByType.Any() ? string.Join(", ", Model.TopicsByType.Keys.Select(k => $"'{k.Replace("'", "\\'")}'")) : "'Brak danych'")],
                        datasets: [{
                            label: 'Liczba tematów',
                            data: [@(Model.TopicsByType.Any() ? string.Join(", ", Model.TopicsByType.Values) : "0")],
                            backgroundColor: [
                                'rgba(118, 186, 255, 0.6)',
                                'rgba(118, 250, 255, 0.6)',
                                'rgba(255, 186, 118, 0.6)',
                                'rgba(255, 118, 186, 0.6)',
                                'rgba(186, 118, 255, 0.6)'
                            ],
                            borderColor: [
                                'rgba(118, 186, 255, 1)',
                                'rgba(118, 250, 255, 1)',
                                'rgba(255, 186, 118, 1)',
                                'rgba(255, 118, 186, 1)',
                                'rgba(186, 118, 255, 1)'
                            ],
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: {
                                labels: { color: '#dfe7ff' },
                                position: 'bottom'
                            }
                        }
                    }
                });
            }

            const usersCtx = document.getElementById('usersChart');
            if (usersCtx) {
                usersChart = new Chart(usersCtx.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: [@Html.Raw(Model.UserRoleStats.Any() ? string.Join(", ", Model.UserRoleStats.Select(k => $"'{k.Key.Replace("'", "\\'")}'")) : "'Brak danych'")],
                        datasets: [{
                            label: 'Liczba użytkowników',
                            data: [@(Model.UserRoleStats.Any() ? string.Join(", ", Model.UserRoleStats.Select(k => k.Value)) : "0")],
                            backgroundColor: [
                                'rgba(118, 186, 255, 0.6)',
                                'rgba(118, 250, 255, 0.6)',
                                'rgba(255, 186, 118, 0.6)',
                                'rgba(255, 118, 186, 0.6)',
                                'rgba(186, 118, 255, 0.6)'
                            ],
                            borderColor: [
                                'rgba(118, 186, 255, 1)',
                                'rgba(118, 250, 255, 1)',
                                'rgba(255, 186, 118, 1)',
                                'rgba(255, 118, 186, 1)',
                                'rgba(186, 118, 255, 1)'
                            ],
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { beginAtZero: true, ticks: { color: '#dfe7ff', stepSize: 1 }, grid: { color: 'rgba(255, 255, 255, 0.12)' } },
                            x: { ticks: { color: '#dfe7ff' }, grid: { color: 'rgba(255, 255, 255, 0.12)' } }
                        }
                    }
                });
            }
        }

        const collapseCharts = document.getElementById('collapseCharts');
        if (collapseCharts) {
            collapseCharts.addEventListener('shown.bs.collapse', function () {
                setTimeout(initCharts, 100);
            });
        }
    </script>
}


