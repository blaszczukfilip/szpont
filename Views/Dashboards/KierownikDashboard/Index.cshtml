@using szpont.Models
@model IEnumerable<szpont.Models.Topic>

@{
    ViewData["Title"] = "Panel Kierownika";
}

<div class="dashboard-page">
    <header class="dashboard-header">
        <h1 class="dashboard-title">Panel kierownika</h1>
        <p class="dashboard-subtitle">Lista tematów oczekujących na akceptację kierownika.</p>
    </header>

    <div class="dashboard-panel">
    <table class="table dashboard-table">
        <thead>
            <tr>
                <th>TYTUŁ</th>
                <th>TYP</th>
                <th>PROMOTOR</th>
                <th>
                    @{
                        var isAsc = ViewBag.CurrentSort == null || ViewBag.CurrentSort == "date_asc";
                        var nextSort = isAsc ? "date_desc" : "date_asc";
                        var arrow = isAsc ? "↑" : "↓";
                    }
                    <a asp-action="Index" asp-route-sortOrder="@nextSort" class="dashboard-sort-link">
                        Data wysłania @arrow
                    </a>
                </th>
                <th>AKCJA</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5">Brak tematów oczekujących na akceptację.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.Type</td>
                        <td>
                            @if (item.Promotor != null)
                            {
                                @($"{item.Promotor.FirstName} {item.Promotor.LastName} ({item.Promotor.Email})")
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                        <td>
                            @(item.SubmittedDate.HasValue
                                ? item.SubmittedDate.Value.ToString("dd.MM.yyyy")
                                : item.CreatedDate.ToString("dd.MM.yyyy"))
                        </td>
                        <td>
                            <a asp-controller="Topics"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-primary btn-sm dashboard-btn">
                                Szczegóły
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
    </div>
</div>


