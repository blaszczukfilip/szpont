@using szpont.Models
@model IEnumerable<szpont.Models.Topic>

@{
    ViewData["Title"] = "Panel Promotora";
}

<div class="dashboard-page">
    <header class="dashboard-header">
        <h1 class="dashboard-title">Panel promotora</h1>
        <p class="dashboard-subtitle">Przegląd tematów według statusu i szybki dostęp do szczegółów.</p>
        @{
            var pendingRes = (int)(ViewBag.PendingReservationsCount ?? 0);
        }
        @if (pendingRes > 0)
        {
            <div class="mt-3">
                <a asp-action="Reservations" class="btn btn-warning">
                    Rezerwacje do akceptacji (@pendingRes)
                </a>
            </div>
        }
        else
        {
            <div class="mt-3">
                <a asp-action="Reservations" class="btn btn-outline-secondary btn-sm">Rezerwacje studentów</a>
            </div>
        }
    </header>

    <div class="dashboard-stats-grid">
        <div class="dashboard-stat-card">
            <h3 class="dashboard-stat-label">Szkice</h3>
            <h4 class="dashboard-stat-value">@ViewBag.CountDraft</h4>
        </div>
        <div class="dashboard-stat-card">
            <h3 class="dashboard-stat-label">W akceptacji</h3>
            <h4 class="dashboard-stat-value is-warning">@ViewBag.CountWaiting</h4>
        </div>
        <div class="dashboard-stat-card">
            <h3 class="dashboard-stat-label">Zaakceptowane</h3>
            <h4 class="dashboard-stat-value is-success">@ViewBag.CountApproved</h4>
        </div>
        <div class="dashboard-stat-card">
            <h3 class="dashboard-stat-label">Odrzucone</h3>
            <h4 class="dashboard-stat-value is-danger">@ViewBag.CountRejected</h4>
        </div>
    </div>

    <h2 class="dashboard-section-title">Szkice (Draft)</h2>
    <div class="dashboard-panel">
    <table class="table dashboard-table">
        <thead>
            <tr>
                <th>TYTUŁ</th>
                <th>TYP</th>
                <th>DATA</th>
                <th>AKCJA</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Where(t => t.Status == TopicStatus.Draft))
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Type</td>
                    <td>@item.CreatedDate.ToString("dd.MM.yyyy")</td>
                    <td><a asp-controller="Topics" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm dashboard-btn">Szczegóły</a></td>
                </tr>
            }
        </tbody>
    </table>
    </div>

    <h2 class="dashboard-section-title is-warning">W trakcie akceptacji</h2>
    <div class="dashboard-panel">
    <table class="table dashboard-table">
        <thead>
            <tr>
                <th>TYTUŁ</th>
                <th>TYP</th>
                <th>STATUS</th>
                <th>AKCJA</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Where(t => t.Status == TopicStatus.WaitingForKierownik || t.Status == TopicStatus.WaitingForDziekan))
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Type</td>
                    <td>@item.Status</td>
                    <td><a asp-controller="Topics" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm dashboard-btn">Szczegóły</a></td>
                </tr>
            }
        </tbody>
    </table>
    </div>

    <h2 class="dashboard-section-title is-success">Zatwierdzone</h2>
    <div class="dashboard-panel">
    <table class="table dashboard-table">
        <thead>
            <tr>
                <th>TYTUŁ</th>
                <th>TYP</th>
                <th>DATA</th>
                <th>AKCJA</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Where(t => t.Status == TopicStatus.Approved))
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Type</td>
                    <td>@item.CreatedDate.ToString("dd.MM.yyyy")</td>
                    <td><a asp-controller="Topics" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm dashboard-btn">Szczegóły</a></td>
                </tr>
            }
        </tbody>
    </table>
    </div>

    <h2 class="dashboard-section-title is-danger">Odrzucone</h2>
    <div class="dashboard-panel">
    <table class="table dashboard-table">
        <thead>
            <tr>
                <th>TYTUŁ</th>
                <th>TYP</th>
                <th>POWÓD</th>
                <th>AKCJA</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Where(t => t.Status == TopicStatus.Rejected))
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Type</td>
                    <td class="dashboard-text-danger">@item.RejectionReason</td>
                    <td><a asp-controller="Topics" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm dashboard-btn">Szczegóły</a></td>
                </tr>
            }
        </tbody>
    </table>
    </div>
</div>
