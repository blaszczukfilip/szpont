@using szpont.Models
@model IEnumerable<szpont.Models.Topic>

@{
    ViewData["Title"] = "Panel Promotora";
}

<div class="dashboard-page">
    <header class="dashboard-header">
        <h1 class="dashboard-title">Panel promotora</h1>
        <p class="dashboard-subtitle">Przegląd tematów według statusu i szybki dostęp do szczegółów.</p>
        <p class="dashboard-subtitle">Tematy dostępne do rezerwacji: @ViewBag.ReservableTopicsCount / @ViewBag.MaxReservableTopics</p>
        @{
            var pendingRes = (int)(ViewBag.PendingReservationsCount ?? 0);
        }
        @if (pendingRes > 0)
        {
            <div class="mt-3">
                <a asp-action="Reservations" class="btn btn-warning">
                    Rezerwacje do akceptacji (@pendingRes)
                </a>
            </div>
        }
        else
        {
            <div class="mt-3">
                <a asp-action="Reservations" class="btn btn-outline-secondary btn-sm">Rezerwacje studentów</a>
            </div>
        }
    </header>
    @{
        var notifications = ViewBag.Notifications as List<szpont.Models.Notification>;
        var unreadCount = (int)(ViewBag.UnreadNotificationsCount ?? 0);
    }

    <div class="notifications-section mb-5">
        <div class="d-flex align-items-center mb-3">
            <h2 class="dashboard-section-title mb-0">Powiadomienia</h2>
            @if (unreadCount > 0)
            {
                <span class="badge bg-danger ms-2" style="border-radius: 4px;">@unreadCount nowe</span>
            }
        </div>

        <div class="dashboard-panel p-0" style="background: transparent; border: none;">
            @if (notifications != null && notifications.Any())
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var notif in notifications.Take(5))
                    {
                        <div class="dashboard-stat-card w-100 text-start p-3"
                             style="border-left: 4px solid @(notif.Type == NotificationType.ReservationCancelled ? "#dc3545" : "#0d6efd");">

                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-2" style="color: @(notif.Type == NotificationType.ReservationCancelled ? "#ff6b6b" : "#4dabf7"); font-weight: 600;">
                                        @if (notif.Type == NotificationType.ReservationCancelled)
                                        {
                                            <span>⚠️ Anulowanie rezerwacji</span>
                                        }
                                        else
                                        {
                                            <span>ℹ️ Nowa rezerwacja</span>
                                        }
                                    </h6>
                                    <p class="mb-2 text-white-50" style="font-size: 0.95rem;">@notif.Message</p>
                                    <a asp-controller="Topics" asp-action="Details" asp-route-id="@notif.TopicId"
                                       class="btn btn-outline-light btn-sm" style="border-color: rgba(255,255,255,0.2); font-size: 0.8rem;">
                                        Szczegóły tematu
                                    </a>
                                </div>
                                <small class="text-muted">@notif.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-3 text-end">
                    <a asp-controller="Notifications" asp-action="Index" class="text-white-50 text-decoration-none" style="font-size: 0.85rem;">
                        Zobacz wszystkie powiadomienia →
                    </a>
                </div>
            }
            else
            {
                <div class="dashboard-stat-card p-4 text-center">
                    <p class="mb-0 text-muted">Brak nowych powiadomień.</p>
                </div>
            }
        </div>
    </div>

    <div class="dashboard-stats-grid">
        <div class="dashboard-stat-card">
            <h3 class="dashboard-stat-label">Szkice</h3>
            <h4 class="dashboard-stat-value">@ViewBag.CountDraft</h4>
        </div>
        <div class="dashboard-stat-card">
            <h3 class="dashboard-stat-label">W akceptacji</h3>
            <h4 class="dashboard-stat-value is-warning">@ViewBag.CountWaiting</h4>
        </div>
        <div class="dashboard-stat-card">
            <h3 class="dashboard-stat-label">Zaakceptowane</h3>
            <h4 class="dashboard-stat-value is-success">@ViewBag.CountApproved</h4>
        </div>
        <div class="dashboard-stat-card">
            <h3 class="dashboard-stat-label">Odrzucone</h3>
            <h4 class="dashboard-stat-value is-danger">@ViewBag.CountRejected</h4>
        </div>
    </div>

    <h2 class="dashboard-section-title">Szkice (Draft)</h2>
    <div class="dashboard-panel">
    <table class="table dashboard-table">
        <thead>
            <tr>
                <th>TYTUŁ</th>
                <th>TYP</th>
                <th>DATA</th>
                <th>AKCJA</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Where(t => t.Status == TopicStatus.Draft))
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Type.GetDisplayName()</td>
                    <td>@item.CreatedDate.ToString("dd.MM.yyyy")</td>
                    <td><a asp-controller="Topics" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm dashboard-btn">Szczegóły</a></td>
                </tr>
            }
        </tbody>
    </table>
    </div>

    <h2 class="dashboard-section-title is-warning">W trakcie akceptacji</h2>
    <div class="dashboard-panel">
    <table class="table dashboard-table">
        <thead>
            <tr>
                <th>TYTUŁ</th>
                <th>TYP</th>
                <th>STATUS</th>
                <th>AKCJA</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Where(t => t.Status == TopicStatus.WaitingForKierownik || t.Status == TopicStatus.WaitingForDziekan))
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Type.GetDisplayName()</td>
                    <td>@item.Status</td>
                    <td><a asp-controller="Topics" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm dashboard-btn">Szczegóły</a></td>
                </tr>
            }
        </tbody>
    </table>
    </div>

    <h2 class="dashboard-section-title is-success">Zatwierdzone</h2>
    <div class="dashboard-panel">
    <table class="table dashboard-table">
        <thead>
            <tr>
                <th>TYTUŁ</th>
                <th>TYP</th>
                <th>DATA</th>
                <th>AKCJA</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Where(t => t.Status == TopicStatus.Approved))
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Type.GetDisplayName()</td>
                    <td>@item.CreatedDate.ToString("dd.MM.yyyy")</td>
                    <td><a asp-controller="Topics" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm dashboard-btn">Szczegóły</a></td>
                </tr>
            }
        </tbody>
    </table>
    </div>

    <h2 class="dashboard-section-title is-danger">Odrzucone</h2>
    <div class="dashboard-panel">
    <table class="table dashboard-table">
        <thead>
            <tr>
                <th>TYTUŁ</th>
                <th>TYP</th>
                <th>POWÓD</th>
                <th>AKCJA</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Where(t => t.Status == TopicStatus.Rejected))
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Type.GetDisplayName()</td>
                    <td class="dashboard-text-danger">@item.RejectionReason</td>
                    <td><a asp-controller="Topics" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm dashboard-btn">Szczegóły</a></td>
                </tr>
            }
        </tbody>
    </table>
    </div>
</div>
