@model szpont.Models.Topic

@{
    ViewData["Title"] = "Panel studenta";
}

<h1>Panel studenta</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="mt-4">
    <h3>Moja rezerwacja</h3>

    @if (Model != null)
    {
        <div class="box">
            <p><strong>Tytuł:</strong> @Model.Title</p>
            <p><strong>Typ:</strong> @Model.Type</p>
            <p><strong>Opis:</strong> @(string.IsNullOrEmpty(Model.Description) ? "Brak opisu" : Model.Description)</p>
            @if (Model.Promotor != null)
            {
                <p><strong>Promotor:</strong> @Model.Promotor.FirstName @Model.Promotor.LastName</p>
            }
            @if (Model.ReservationDate.HasValue)
            {
                <p><strong>Data rezerwacji:</strong> @Model.ReservationDate.Value.ToString("dd.MM.yyyy HH:mm")</p>
            }

            <div class="mt-3 d-flex gap-2">
                <a asp-controller="Topics" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary">
                    Szczegóły
                </a>
                <form asp-controller="Topics" asp-action="CancelReservation" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">
                        Anuluj rezerwację
                    </button>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Nie masz jeszcze zarezerwowanego tematu.
            <a asp-controller="Topics" asp-action="Index">Przeglądaj dostępne tematy</a>
        </div>
    }
</div>

<style>
    .box {
        margin-top: 15px;
        padding: 15px;
        border-radius: 8px;
        background-color: rgba(40, 40, 40, 0.95);
        color: #fff;
        border: 1px solid #555;
    }
</style>
