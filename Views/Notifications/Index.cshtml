@using szpont.Models
@model IEnumerable<szpont.Models.Notification>

@{
    ViewData["Title"] = "Powiadomienia";
    var isStudent = ViewBag.IsStudent as bool? == true;
}

<div class="dashboard-page">
    <header class="dashboard-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="dashboard-title">Powiadomienia</h1>
                <p class="dashboard-subtitle">
                    @(isStudent
                        ? "Decyzje promotora dotyczące Twoich rezerwacji tematów."
                        : "Lista powiadomień o rezerwacjach tematów przez studentów.")
                </p>
            </div>
            @if (Model.Any(n => !n.IsRead))
            {
                <form asp-action="MarkAllAsRead" method="post">
                    <button type="submit" class="btn btn-outline-primary dashboard-btn">
                        Oznacz wszystkie jako przeczytane
                    </button>
                </form>
            }
        </div>
    </header>

    @if (!Model.Any())
    {
        <div class="dashboard-panel">
            <p class="dashboard-empty">Brak powiadomień.</p>
        </div>
    }
    else
    {
        <div class="dashboard-panel">
            <table class="table dashboard-table">
                <thead>
                    <tr>
                        <th style="width: 40px;"></th>
                        <th>WIADOMOŚĆ</th>
                        <th>TEMAT</th>
                        <th>DATA</th>
                        <th>AKCJA</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var notification in Model)
                    {
                        <tr class="@(!notification.IsRead ? "notification-unread" : "")">
                            <td>
                                @if (!notification.IsRead)
                                {
                                    <span class="notification-dot" title="Nieprzeczytane"></span>
                                }
                            </td>
                            <td>
                                <div class="notification-message">
                                    @notification.Message
                                </div>
                                @if (!isStudent && notification.Student != null)
                                {
                                    <small class="text-muted">
                                        Student: @notification.Student.FirstName @notification.Student.LastName
                                        (@notification.Student.Email)
                                    </small>
                                }
                            </td>
                            <td>
                                @if (notification.Topic != null)
                                {
                                    <a asp-controller="Topics" asp-action="Details" asp-route-id="@notification.TopicId">
                                        @notification.Topic.Title
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @notification.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                            </td>
                            <td>
                                @if (!notification.IsRead)
                                {
                                    <form asp-action="MarkAsRead" asp-route-id="@notification.Id" method="post" style="display: inline;">
                                        <button type="submit" class="btn btn-sm btn-outline-success dashboard-btn">
                                            Oznacz jako przeczytane
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted" style="font-size: 0.85rem;">
                                        Przeczytane @notification.ReadAt?.ToString("dd.MM.yyyy HH:mm")
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .notification-unread {
        background: rgba(118, 186, 255, 0.08) !important;
    }

    .notification-dot {
        display: inline-block;
        width: 10px;
        height: 10px;
        background: var(--dashboard-color-primary, #76baff);
        border-radius: 50%;
    }

    .notification-message {
        font-weight: 500;
        margin-bottom: 0.25rem;
    }
</style>
