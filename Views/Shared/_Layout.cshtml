<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Szpont</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard-common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/szpont.styles.css" asp-append-version="true" />

    <style>
        html, body {
            height: 100%;
            margin: 0;
            display: flex;
            flex-direction: column;
            background-color: #121212;
            color: #f1f1f1;
        }

        body {
            background-image: url('/images/background.png');
            background-size: auto;
            background-repeat: no-repeat;
            background-position: center center;
            background-attachment: fixed;
        }

            body::before {
                content: "";
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                z-index: -1;
            }

        .navbar {
            background-color: #1f1f1f !important;
            border-bottom: 1px solid #333;
        }

            .navbar a {
                color: #f1f1f1 !important;
                transition: color 0.2s;
            }

                .navbar a:hover {
                    color: #76faff !important;
                }

        .container {
            flex: 1;
            border-radius: 10px;
            padding: 20px;
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(15px);
            background: rgba(255,255,255,0.05);
        }

        footer {
            background: rgba(0,0,0,0.3);
            color: #ccc;
        }

        a {
            color: #76b7ff;
        }

            a:hover {
                color: #a9d3ff;
            }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Szpont</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Topics" asp-action="Index">Tematy</a>
                        </li>
                        <!--przycisk "Użytkownicy" widoczny tylko przez administratora-->
                        @if (User?.Identity?.IsAuthenticated == true && User.IsInRole("admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="AdminUsers" asp-action="Index">Użytkownicy</a>
                            </li>
                        }
                    </ul>    
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="text-center mt-auto">
        <div class="container">
            &copy; 2025 - szpont - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
