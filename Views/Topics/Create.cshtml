@model szpont.Models.Topic

@{
    ViewData["Title"] = "Dodaj temat";
}

<h2 class="mb-3">Dodaj temat pracy dyplomowej</h2>


<div class="form-box">
    <form asp-action="Create" method="post">

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-field">
            <label asp-for="Title">Tytuł *</label>
            <input asp-for="Title" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="form-field">
            <label asp-for="Description">Opis</label>
            <textarea asp-for="Description" rows="5"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-field">
            <label asp-for="Type">Typ *</label>
            <select asp-for="Type">
                <option value="">-- wybierz --</option>
                <option>Licencjacka</option>
                <option>Inżynierska</option>
                <option>Magisterska</option>
                <option>Doktorska</option>
            </select>
            <span asp-validation-for="Type" class="text-danger"></span>
        </div>

        <div class="form-field">
            <label asp-for="Keywords">Słowa kluczowe</label>
            <input asp-for="Keywords" />
            <span asp-validation-for="Keywords" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-lg">Zapisz</button>
            <a asp-action="Index" class="btn btn-secondary btn-lg">Anuluj</a>
        </div>

    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
.form-box {
    padding: 25px;
    margin-bottom: 35px;
    background: rgba(50, 50, 50, 0.9);
    border: 1px solid #777;
    border-radius: 10px;
    color: #fff;
}

.form-field {
    margin-bottom: 20px;
}

.form-box label {
    display: block;
    font-weight: 600;
    margin-bottom: 5px;
    color: #ddd;
}

.form-box input,
.form-box textarea,
.form-box select {
    width: 100%;
    padding: 12px 15px;
    border-radius: 8px;
    border: 1px solid #555;
    background-color: #222;
    color: #fff;
    box-sizing: border-box;
    font-size: 14px;
}

.form-box textarea {
    resize: vertical;
}

.form-box input::placeholder {
    color: #aaa;
}
</style>